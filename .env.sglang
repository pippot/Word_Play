# ---------------------------------------------------------------------------
# Runtime environment for the SGLang server.
# Load with:  uv run --env-file .env.sglang python -m sglang.launch_server ...
# ---------------------------------------------------------------------------

# sgl-kernel's .so files link against CUDA 12 libs installed by pip.
# The .venv path is relative so it works from the project root.
LD_LIBRARY_PATH=.venv/lib/python3.13/site-packages/nvidia/cuda_nvrtc_cu12/lib:.venv/lib/python3.13/site-packages/nvidia/cublas_cu12/lib:.venv/lib/python3.13/site-packages/nvidia/cuda_cupti_cu12/lib:.venv/lib/python3.13/site-packages/nvidia/cuda_runtime_cu12/lib

# Suppress PyTorch 2.9 / CuDNN version warning (benign with current setup).
SGLANG_DISABLE_CUDNN_CHECK=1

# Some packages (e.g. deep_gemm) probe CUDA_HOME during import.
CUDA_HOME=/usr/local/cuda
